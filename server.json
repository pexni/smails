{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.pexni/smails",
  "title": "smails",
  "description": "Free disposable email for AI agents — no API key, no signup. Create a throwaway inbox and read verification codes and magic links over MCP.",
  "websiteUrl": "https://smails.dev",
  "repository": {
    "url": "https://github.com/pexni/smails",
    "source": "github",
    "subfolder": "cli"
  },
  "version": "0.0.10",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@smails/cli",
      "version": "0.0.10",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ]
    }
  ]
}
